# Copy to `.env` at the repo root. Gradle reads it at build time and injects these into BuildConfig.
# Every value is OPTIONAL: the launcher, search, Trace, and the blocking layer all work without them.
#
# SECURITY: whatever you put here is compiled into the APK as plaintext and is trivially
# extractable from any distributed build. Never attach an APK built with real keys to a public
# GitHub release. Keep keyed builds private, or leave these blank for any build you share.

# Groq API key. Enables voice transcription and the voice launch agent.
# Without it, voice memos stay queued (no transcription) and voice launch falls back to fuzzy match.
GROQ_API_KEY=

# Fine-grained GitHub PAT with Issues: read & write on your OTTO_GITHUB_REPO.
# Used only by in-app "Send feedback" to open issues. Without it, feedback is disabled.
GITHUB_FEEDBACK_TOKEN=

# GitHub repo (owner/name) the in-app updater and feedback target.
# A fork should set this to its own repo. Defaults to jkasimotto/otto-android when blank.
OTTO_GITHUB_REPO=
